<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/ivLocusLogo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_locus"
                android:scaleType="fitCenter"
                android:contentDescription="Locus Maps" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Locus Brose Adapter"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Not connected"
                    android:textSize="12sp"
                    android:textColor="#9E9E9E" />
            </LinearLayout>
        </LinearLayout>

        <!-- LIVE VALUES CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE VALUES"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:paddingBottom="14dp" />

            <!-- Row 1: Speed / Cadence / Assist Mode -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="14dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Speed" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvSpeed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— km/h" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cadence" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvCadence" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— rpm" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Assist Mode" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvAssist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: Rider Power / Battery % / Range -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="14dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rider Power" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvRiderPower" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— W" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Battery" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvBattery" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— %" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Range" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvRange" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— km" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 3: Odometer / Trip / Motor Temp -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="14dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Odometer" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvOdometer" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— km" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trip" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvTrip" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— km" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Motor Temp" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvMotorTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— °C" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 4: Pedal Torque / Light / Batt Capacity -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="14dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pedal Torque" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvTorque" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— Nm" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Light" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvLight" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="—" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batt Capacity" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvBattWh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— Wh" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 5: Voltage / Batt Temp / Profile Scale -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Voltage" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvVoltage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— V" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batt Temp" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvBattTemp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— °C" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile Scale" android:textSize="11sp" android:textColor="#757575"/>
                    <TextView android:id="@+id/tvProfScale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="— %" android:textSize="17sp" android:textStyle="bold" android:textColor="#1A1A2E"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- CONTROLS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTROLS"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assist Mode"
                android:textSize="12sp"
                android:textColor="#424242"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="16dp">

                <Button android:id="@+id/btnOff"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="OFF" android:textSize="11sp" android:layout_marginEnd="3dp"
                    android:minHeight="0dp" android:paddingTop="0dp" android:paddingBottom="0dp"/>
                <Button android:id="@+id/btnEco"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="ECO" android:textSize="11sp" android:layout_marginEnd="3dp"
                    android:minHeight="0dp" android:paddingTop="0dp" android:paddingBottom="0dp"/>
                <Button android:id="@+id/btnTour"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="TOUR" android:textSize="11sp" android:layout_marginEnd="3dp"
                    android:minHeight="0dp" android:paddingTop="0dp" android:paddingBottom="0dp"/>
                <Button android:id="@+id/btnSport"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="SPORT" android:textSize="11sp" android:layout_marginEnd="3dp"
                    android:minHeight="0dp" android:paddingTop="0dp" android:paddingBottom="0dp"/>
                <Button android:id="@+id/btnBoost"
                    android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                    android:text="BOOST" android:textSize="11sp"
                    android:minHeight="0dp" android:paddingTop="0dp" android:paddingBottom="0dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvScalingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Scaling: —"
                android:textSize="12sp"
                android:textColor="#424242"
                android:paddingBottom="6dp" />

            <SeekBar
                android:id="@+id/seekScaling"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100" />

        </LinearLayout>

        <!-- DIAGNOSTICS CARD (collapsible) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="14dp">

            <LinearLayout
                android:id="@+id/layoutDiagHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DIAGNOSTICS"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0" />

                <TextView
                    android:id="@+id/tvDiagToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textSize="13sp"
                    android:textColor="#9E9E9E" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutDiagContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="10dp">

                <TextView
                    android:id="@+id/tvDiag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:typeface="monospace"
                    android:textColor="#424242"
                    android:paddingBottom="10dp" />

                <Button
                    android:id="@+id/btnCopy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Copy to clipboard" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
